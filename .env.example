# Local SQL Server / WideWorldImporters configuration
#
# Do not put real passwords in source control. Copy this file to .env locally
# only if your own tooling loads .env files.

SQLSERVER_HOST=050027346-3
SQLSERVER_PORT=
SQLSERVER_DB=WideWorldImporters

# windows = local trusted connection
# sql = SQL Server username/password, intended for later Azure-to-laptop POC
SQLSERVER_AUTH_MODE=windows
SQLSERVER_USER=
SQLSERVER_PASSWORD=

# ODBC Driver 17 preserves the current local Cursor setup.
# Later container/Azure work will use ODBC Driver 18 where available.
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_ENCRYPT=no
SQLSERVER_TRUST_CERT=yes

QUERY_TIMEOUT_SECONDS=15
MAX_QUERY_ROWS=500
SQLSERVER_APPROVED_SCHEMAS=Application,Sales,Purchasing,Warehouse

LOG_LEVEL=INFO

# HTTP server settings for server_http.py
HOST=0.0.0.0
PORT=8000
MCP_HTTP_PATH=/mcp

# Optional local state directory override for memory/log files.
MCP_STATE_DIR=
